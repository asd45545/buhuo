# Copy to /etc/ldxp-dashboard.env, generate a password hash, set the exact
# public HTTPS origin, then chmod 600.
LDXP_DASHBOARD_HOST=127.0.0.1
LDXP_DASHBOARD_PORT=8788
LDXP_DASHBOARD_STATUS_FILE=/var/lib/ldxp-monitor/ldxp-monitor-status.json
LDXP_DASHBOARD_SECURITY_FILE=/var/lib/ldxp-dashboard/auth-state.json
LDXP_DASHBOARD_PASSWORD_HASH=
LDXP_DASHBOARD_PUBLIC_ORIGIN=
LDXP_DASHBOARD_TRUST_PROXY=true
LDXP_DASHBOARD_SECURE_COOKIE=true
LDXP_DASHBOARD_COOKIE_NAME=__Secure-ldxp_session
LDXP_DASHBOARD_COOKIE_PATH=/stock-monitor/
LDXP_DASHBOARD_SESSION_TTL_MS=2592000000
LDXP_DASHBOARD_MAX_FAILURES=3
LDXP_DASHBOARD_BAN_MS=86400000
# SHA-256 hex digest of a 32-byte base64url inventory API key.
LDXP_INVENTORY_API_KEY_HASH=
# Comma-separated exact HTTPS origins. Leave empty for server-to-server only.
LDXP_INVENTORY_API_ALLOWED_ORIGINS=
LDXP_INVENTORY_API_RATE_LIMIT=120
