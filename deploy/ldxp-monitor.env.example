# Copy to /etc/ldxp-monitor.env, set real values, then chmod 600.
LDXP_API_TRANSPORT=auto
LDXP_BROWSER_HEADLESS=false
LDXP_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
LDXP_BROWSER_PROFILE_DIR=/var/lib/ldxp-monitor/browser-profile
LDXP_BROWSER_PROXY_SERVER=direct
# Keep authenticated proxy credentials separate from the server URL.
LDXP_BROWSER_PROXY_USERNAME=
LDXP_BROWSER_PROXY_PASSWORD=
# Optional: override only when the installed Chromium major version changes materially.
# LDXP_BROWSER_USER_AGENT=Mozilla/5.0 ... Chrome/150.0.0.0 ...
LDXP_REQUEST_TIMEOUT_MS=15000
LDXP_API_RETRIES=3
LDXP_API_RETRY_DELAY_MS=1500
LDXP_DAEMON_INTERVAL_MS=300000
LDXP_STATUS_FILE=/var/lib/ldxp-monitor/ldxp-monitor-status.json

# Telegram notifications. Never commit real values.
LDXP_TELEGRAM_BOT_TOKEN=
LDXP_TELEGRAM_CHAT_ID=
LDXP_TELEGRAM_THREAD_ID=
